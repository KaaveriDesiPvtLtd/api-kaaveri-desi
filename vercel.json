{
  "version": 2,
  "name": "kaaveri-desi-backend",
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/crm/auth/(.*)",
      "dest": "app.js"
    },
    {
      "src": "/api/crm/(.*)",
      "dest": "app.js"
    },
    {
      "src": "/(.*)",
      "dest": "app.js"
    }
  ]
}
